
DATABASE_URL=postgresql://leaduser:leadpassword@db:5432/leadengine

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Enable Redis Queue System (set to 'true' for production)
USE_REDIS=true

# Telegram Integration (Optional but recommended for exports)
# 1. Create bot: Message @BotFather on Telegram, use /newbot
# 2. Copy the token it gives you
TELEGRAM_BOT_TOKEN=8494513906:AAHi-b3iDkRwP6IthiW6Aw4b-STrZhLliP8

# 3. Message your bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 4. Find "chat":{"id": NUMBER} and copy that number
TELEGRAM_CHAT_ID=your_chat_id_here

# For local development without Docker:
# DATABASE_URL=sqlite:///./leadengine.db
